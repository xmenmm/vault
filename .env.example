# Create a FRESH Supabase project for this vault (do not reuse old keys).
# Supabase dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Use the LEGACY anon (public) JWT key here — tab "Legacy anon, service_role"
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role — SERVER ONLY (used solely to create the auth user on signup).
# Never expose to the client. Legacy service_role key.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Random secret used to sign the session cookie (any long random string).
# Generate one: `openssl rand -base64 48`
SESSION_SECRET=change-me-to-a-long-random-string

# ── WhatsApp 2FA (OPTIONAL) ──────────────────────────────────────────────
# Only needed if you want login codes delivered over WhatsApp. Leave unset to
# keep 2FA on authenticator (TOTP) only — the WhatsApp option simply won't show.
# From Meta: developers.facebook.com → your app → WhatsApp → API Setup.
#   - PHONE_NUMBER_ID: the Cloud API phone-number id (NOT the phone number).
#   - ACCESS_TOKEN: a permanent System User token (whatsapp_business_messaging).
#   - OTP_TEMPLATE: name of an APPROVED "authentication"-category template with
#                   one body variable (the code) and a copy-code button.
#   - OTP_LANG: that template's language code (e.g. en_US or id).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE=
WHATSAPP_OTP_LANG=en_US
