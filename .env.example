# Create a FRESH Supabase project for this vault (do not reuse old keys).
# Supabase dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Use the LEGACY anon (public) JWT key here — tab "Legacy anon, service_role"
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role — SERVER ONLY (used solely to create the auth user on signup).
# Never expose to the client. Legacy service_role key.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
